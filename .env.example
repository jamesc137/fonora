# Fonoran Google OAuth (loaded automatically from .env on npm start: local dev only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# Only @fonora.org accounts may sign in (default: fonora.org)
ALLOWED_DOMAIN=fonora.org

# Optional: restrict to specific emails instead of whole domain
# ADMIN_EMAILS=info@fonora.org

# Optional: force callback URL (default: derived from request host)
# AUTH_CALLBACK_URL=http://localhost:8000/auth/callback

# Local dev: skip auth even when OAuth vars are set
# FONORAN_AUTH=off   # local opt-out only — omit in production (Heroku)

# Fonoran storage (optional)
# DATABASE_URL=
# FONORAN_STORAGE=postgres
# FONORAN_SKIP_JSON_MIRROR=1
