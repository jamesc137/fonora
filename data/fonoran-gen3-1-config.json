  ],

  "generation": {
    "syllable_template": "CV",
    "max_repair_steps": 20,
    "max_vowel_ending_per_class": 3,
    "manner_rotation": ["plain", "voice", "friction", "nasal", "glide"],
    "repair_triggers": ["null_onset", "duplicate_root", "distinctiveness_violation"],
    "no_human_lexicon_repair": true,
    "distinctiveness_weights": {
      "duplicate_root": 10000,
      "prefix_overlap": 5000,
      "vowel_ending_cap": 800,
      "same_onset": 120,
      "same_rhyme": 80,
      "one_vowel_diff": 90,
      "one_onset_diff": 70,
      "similarity_high": 100
    },
    "allowed_prefix_pairs": []
  },

  "phonetic_realization": {
    "note": "Semantic aspect (A) is fixed in coordinates. Phonetic vowel is chosen from Fonora-native pools to spread rhyme classes, not an English borrowing layer.",
    "aspect_vowel_pools": {
      "contact": ["u", "o", "a", "oh", "i", "e", "ee", "ae"],
      "focal": ["i", "e", "o", "u", "a", "ae", "oh", "ee"],
      "struct": ["i", "e", "o", "u", "a", "ee", "ae", "oh"],
      "field": ["o", "u", "a", "i", "e", "oh", "ae", "ee"],
      "source": ["a", "o", "u", "oh", "e", "i", "ee", "ae"],
      "animated": ["e", "i", "o", "u", "a", "ee", "ae", "oh"],
