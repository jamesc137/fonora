      "concept": "river",
      "not_primitive": true,
      "composition": ["flow", "path"],
      "gloss": "continuous change along directed passage",
      "coordinate_gloss": "⟨emanation,flux,turbulent⟩ + ⟨index,passage,struct⟩"
    },
    {
      "concept": "planet",
      "not_primitive": true,
      "composition": ["bound", "field", "motion"],
      "gloss": "edge + extended presence + index in transit",
      "coordinate_gloss": "⟨interface,packet,focal⟩ + ⟨emanation,packet,field⟩ + ⟨index,passage,animated⟩"
    },
    {
      "concept": "speaker",
      "not_primitive": true,
