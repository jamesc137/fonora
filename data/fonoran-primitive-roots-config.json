{
  "version": "1.0-primitive-roots",
  "description": "Semantic primitive inventory for algorithmic root generation. Concepts are ranked by fundamentality; composites are listed only as exclusions.",
  "philosophy": {
    "source": "docs/fonoran-grammar.md",
    "premise": "Invariant concept roots; grammar via particles; compounds are transparent trees.",
    "phonetic_strategy": "Huffman-like: higher fundamentality → lower phonetic cost (shorter, simpler syllables)."
  },
  "reserved_particles": {
    "note": "Never assign as lexical roots. From grammar placeholders and planned inventory.",
    "forms": ["mi", "ta", "na"]
  },
  "excluded_syllables": {
    "note": "Awkward or humorous; deferred to later expansion.",
    "forms": ["pi", "pee", "po", "poo"]
  },
  "phonetics": {
    "preferred_onsets": ["b", "d", "f", "g", "k", "l", "m", "n", "s", "t"],
    "secondary_onsets": ["h", "w", "y"],
    "tertiary_onsets": ["p", "ch", "sh", "j", "r"],
    "vowels_by_cost": ["a", "e", "i", "o", "u"],
    "coda_onsets": ["b", "d", "f", "g", "k", "l", "m", "n", "s", "t"],
    "max_cv_per_rhyme": 4,
    "max_same_onset": 5
  },
  "excluded_composites": [
    "tribe", "family", "government", "language", "nation", "religion",
    "war", "community", "speaker", "memory", "river", "planet", "storm",
    "home", "city", "house", "book", "sentence", "knowledge", "wisdom"
