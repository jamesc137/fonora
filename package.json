{
  "name": "fonora",
  "version": "0.1.0",
  "description": "Open-source phonetic oral script language, research tools and documentation",
  "homepage": "https://fonora.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesc137/fonora.git"
  },
  "bugs": {
    "url": "https://github.com/jamesc137/fonora/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/copy-espeak.js && node scripts/copy-espeak-audio.js && node scripts/copy-onnx-wasm.js && node scripts/copy-piper.js",
    "start": "node server.js",
    "test": "node js/tests.js && npm run test:translator",
    "test:translator": "node scripts/fonoran-translation-gaps.js --assert",
    "test:translator:update": "node scripts/fonoran-translation-gaps.js --update-golden",
    "test:vowels": "node scripts/vowel-readability-report.js",
    "test:minimal-pairs": "node scripts/vowel-v2-collision-report.js",
    "test:v2-collisions": "npm run test:minimal-pairs",
    "audit:collisions": "node scripts/collision-audit.js",
    "test:pronunciation-validation": "node scripts/pronunciation-validation-report.js",
    "audit:ipa-vowels": "node scripts/ipa-vowel-normalization-audit.js",
    "report:ipa-diagnostics": "node scripts/ipa-normalization-diagnostics.js",
    "fonoran:gen3": "node tools/fonoran-gen3.js",
    "fonoran:gen3:1": "node tools/fonoran-gen3-1.js",
    "fonoran:gen3:compare": "node tools/fonoran-gen3-1-compare.js",
    "fonoran:gen3:audit": "node tools/fonoran-gen3-audit.js",
    "fonoran:gen3:semantic": "node tools/fonoran-gen3-semantic-audit.js",
    "fonoran:canonical:init": "node tools/fonoran-canonical-stabilize.js",
    "fonoran:canonical:constitution": "node tools/fonoran-canonical-stabilize.js",
    "fonoran:stress-test": "node tools/fonoran-stress-test.js",
    "fonoran:explore": "node -e \"console.log('Open http://localhost:' + (process.env.PORT||8000) + '/language/')\"",
    "fonoran:import": "node scripts/fonoran-import-json.js",
    "fonoran:export": "node scripts/fonoran-export-json.js",
    "research:import": "node scripts/research-notes-import-static.js",
    "fonoran:snapshot:export": "node scripts/fonoran-snapshot-export.js",
    "fonoran:snapshot:import": "node scripts/fonoran-snapshot-import.js",
    "fonoran:roots": "node tools/fonoran-english-roots-build.js",
    "fonoran:lexicon": "node -e \"import('./tools/fonoran-english-lexicon.js').then(m => m.writeEnglishLexicon().then(l => console.log('Lexicon:', l.word_count, 'words')))\"",
    "fonoran:reset": "node tools/fonoran-reset.js",
    "fonoran:build": "node tools/fonoran-build.js",
    "fonoran:build:approved": "node tools/fonoran-build.js --approve-all",
    "fonoran:root-candidates": "node tools/fonoran-root-candidates.js",
    "fonoran:inventory-migrate": "node tools/fonoran-inventory-migrate.js",
    "fonoran:reconcile-inventory": "node scripts/fonoran-reconcile-inventory.js",
    "fonoran:root-capacity": "node scripts/fonoran-root-capacity.js",
    "fonoran:root-capacity:tiers": "node scripts/fonoran-root-capacity-tiers.js",
    "fonoran:primitive-roots": "node -e \"console.error('DEPRECATED: use npm run fonoran:build (converged pipeline). See docs/fonoran.md')\" && exit 1",
    "fonoran:primitive-roots:gen": "node -e \"console.error('DEPRECATED: use npm run fonoran:build')\" && exit 1",
    "fonoran:primitive-roots:import": "node -e \"console.error('DEPRECATED: use npm run fonoran:build')\" && exit 1"
  },
  "dependencies": {
    "@echogarden/espeak-ng-emscripten": "^0.3.5",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "espeak-ng": "^1.0.2",
    "onnxruntime-web": "1.20.1",
    "pg": "^8.22.0",
    "piper-tts-web": "^1.1.2",
    "wordpos": "^2.1.0"
  }
}
