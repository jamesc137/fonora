{
  "name": "fonora",
  "version": "0.1.0",
  "description": "Open-source phonetic oral script language — research tools and documentation",
  "homepage": "https://fonora.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesc137/fonora.git"
  },
  "bugs": {
    "url": "https://github.com/jamesc137/fonora/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/copy-espeak.js && node scripts/copy-espeak-audio.js && node scripts/copy-onnx-wasm.js && node scripts/copy-piper.js",
    "start": "node server.js",
    "test": "node js/tests.js",
    "test:vowels": "node scripts/vowel-readability-report.js",
    "test:minimal-pairs": "node scripts/vowel-v2-collision-report.js",
    "test:v2-collisions": "npm run test:minimal-pairs",
    "audit:collisions": "node scripts/collision-audit.js",
    "test:pronunciation-validation": "node scripts/pronunciation-validation-report.js",
    "audit:ipa-vowels": "node scripts/ipa-vowel-normalization-audit.js",
    "report:ipa-diagnostics": "node scripts/ipa-normalization-diagnostics.js"
  },
  "dependencies": {
    "@echogarden/espeak-ng-emscripten": "^0.3.5",
    "espeak-ng": "^1.0.2",
    "piper-tts-web": "^1.1.2"
  }
}
